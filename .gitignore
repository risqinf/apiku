# --- Rust build artefacts ---
/target
# Note: Cargo.lock IS committed for binary crates so CI builds reproducibly.

# --- App output ---
output.json
*.log

# --- IDE / editor metadata (local only) ---
.helix/
.hx/
.kiro/
.vscode/
.idea/
*.swp
*.swo

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini

# --- Local secrets / config overrides ---
.env
.env.local
config.local.toml
# Auto-generated opaque-ID signing secret (keeps IDs/image URLs stable across
# restarts). Per-deployment; never commit.
.apiku-secret
/.apiku/
/.apiku-test/
.apiku-test-id

# --- Operator-specific static files (verification, ads, sitemaps) ---
# Keep the directory + its docs/robots, but don't commit per-deployment files.
/public/*
!/public/README.md
!/public/robots.txt

